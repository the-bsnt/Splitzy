{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.2"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "title": "cAdvisor - Container Metrics & Health",
  "uid": "cadvisor-container-metrics",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["cadvisor", "docker", "containers"],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_last_seen{name!=\"\"}, name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Containers",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(container_last_seen{name=~\"$container\"})",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Container CPU %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"$container\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Container Memory",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=~\"$container\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Containers Restarted (last 1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(changes(container_start_time_seconds{name=~\"$container\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 101,
      "type": "row",
      "title": "CPU & Memory per Container",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage % by Container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"$container\"}[5m])) by (name) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage by Container",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=~\"$container\"}) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Current Memory Usage by Container (ranked)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=~\"$container\"}) by (name)",
          "legendFormat": "{{name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "Current CPU Usage by Container (ranked)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"$container\"}[5m])) by (name) * 100",
          "legendFormat": "{{name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Network & Filesystem per Container",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Network I/O by Container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=~\"$container\"}[5m])) by (name)",
          "legendFormat": "RX {{name}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=~\"$container\"}[5m])) by (name)",
          "legendFormat": "TX {{name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Filesystem Usage by Container",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(container_fs_usage_bytes{name=~\"$container\"}) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Filesystem I/O by Container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_fs_reads_bytes_total{name=~\"$container\"}[5m]) + rate(container_fs_writes_bytes_total{name=~\"$container\"}[5m])) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Container Process/Thread Count",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_processes{name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 103,
      "type": "row",
      "title": "Container Status & Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 }
    },
    {
      "id": 30,
      "type": "table",
      "title": "Container Inventory",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_last_seen{name=~\"$container\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "id": true,
              "job": true,
              "instance": true
            },
            "renameByName": { "name": "Container", "image": "Image" }
          }
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Restart Events per Container",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "cAdvisor doesn't expose Docker HEALTHCHECK status directly - this tracks container start-time resets as a restart proxy. For true HEALTHCHECK status (healthy/unhealthy/starting), add a custom exporter that polls 'docker inspect' State.Health.Status.",
      "targets": [
        {
          "expr": "changes(container_start_time_seconds{name=~\"$container\"}[1h])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "Pressure & Resilience",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "CPU Throttling Rate",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_cfs_throttled_seconds_total{name=~\"$container\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Memory Working Set vs Limit %",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (container_memory_working_set_bytes{name=~\"$container\"} / clamp_min(container_spec_memory_limit_bytes{name=~\"$container\"}, 1))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 34,
      "type": "stat",
      "title": "Containers Above 80% Memory Limit",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 57 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count((100 * (container_memory_working_set_bytes{name=~\"$container\"} / clamp_min(container_spec_memory_limit_bytes{name=~\"$container\"}, 1))) > 80)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 35,
      "type": "stat",
      "title": "Restarts in Last 1h",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 57 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(changes(container_start_time_seconds{name=~\"$container\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    }
  ]
}
