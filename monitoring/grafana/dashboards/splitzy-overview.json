{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.2"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "title": "Docker Stack Observability - Host, Containers, Health & Logs",
  "uid": "docker-observability",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["docker", "prometheus", "loki", "cadvisor", "node-exporter"],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(container_last_seen{name!=\"\"}, name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(service)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "API Service",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count_over_time(container_last_seen{name=~\"(?i).*(api|backend|splitzy-backend).*\"}[5m]) > bool 0",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Frontend Service",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count_over_time(container_last_seen{name=~\"(?i).*(frontend|app|splitzy-frontend).*\"}[5m]) > bool 0",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Postgres Service",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count_over_time(container_last_seen{name=~\"(?i).*(postgres|postgres-db).*\"}[5m]) > bool 0",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Core Services Up",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((count_over_time(container_last_seen{name=~\"(?i).*(api|backend|splitzy-backend).*\"}[5m]) > bool 0) + (count_over_time(container_last_seen{name=~\"(?i).*(frontend|app|splitzy-frontend).*\"}[5m]) > bool 0) + (count_over_time(container_last_seen{name=~\"(?i).*(postgres|postgres-db).*\"}[5m]) > bool 0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "max": 3,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Host Memory Usage %",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * (1 - ((node_memory_MemAvailable_bytes) / (node_memory_MemTotal_bytes)))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Host Disk Usage % (root)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 101,
      "type": "row",
      "title": "Host Metrics (Node Exporter)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage Over Time",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "Read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "Write {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Network Traffic (Host)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "System Load Average (1m/5m/15m)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15", "legendFormat": "15m", "refId": "C" }
      ]
    },

    {
      "id": 102,
      "type": "row",
      "title": "Per-Container Metrics (cAdvisor)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Container CPU Usage %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"$container\"}[5m])) by (name) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Container Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=~\"$container\"}) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Container Network I/O",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=~\"$container\"}[5m])) by (name)",
          "legendFormat": "RX {{name}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=~\"$container\"}[5m])) by (name)",
          "legendFormat": "TX {{name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Container Filesystem Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(container_fs_usage_bytes{name=~\"$container\"}) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },

    {
      "id": 103,
      "type": "row",
      "title": "Container Health & Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 }
    },
    {
      "id": 30,
      "type": "table",
      "title": "Container Status Table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "container_last_seen{name=~\"$container\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "id": true,
              "image": true,
              "job": true,
              "instance": true
            },
            "renameByName": { "name": "Container" }
          }
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Container Restarts (rate of process count changes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": "Prometheus",
      "description": "cAdvisor doesn't expose Docker HEALTHCHECK status directly. This tracks container start-time resets as a proxy for restarts. For true HEALTHCHECK status, add a small docker-state exporter (e.g. containrrr/watchtower metrics or a custom script exporter).",
      "targets": [
        {
          "expr": "changes(container_start_time_seconds{name=~\"$container\"}[1h])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 104,
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 }
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Log Volume by Service",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 53 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Error Log Rate by Service",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 53 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)error|exception|fatal\" [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      }
    },
    {
      "id": 42,
      "type": "logs",
      "title": "Live Log Stream",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 59 },
      "datasource": "Loki",
      "targets": [{ "expr": "{service=~\"$service\"}", "refId": "A" }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
