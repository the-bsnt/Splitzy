{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.2"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "title": "Prometheus - Host Metrics (Node Exporter)",
  "uid": "prometheus-host-metrics",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["prometheus", "node-exporter", "host"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Node Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"node-exporter\", instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU Cores",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "CPU Usage %",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m])) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Memory Usage %",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - ((node_memory_MemAvailable_bytes{instance=~\"$instance\"}) / (node_memory_MemTotal_bytes{instance=~\"$instance\"})))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Disk Usage % (root)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\", instance=~\"$instance\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\", instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 101,
      "type": "row",
      "title": "CPU & Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage Over Time (by mode)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{instance=~\"$instance\"}[5m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage Over Time",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=~\"$instance\"}",
          "legendFormat": "Available",
          "refId": "B"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=~\"$instance\"}",
          "legendFormat": "Cached",
          "refId": "C"
        },
        {
          "expr": "node_memory_SwapTotal_bytes{instance=~\"$instance\"} - node_memory_SwapFree_bytes{instance=~\"$instance\"}",
          "legendFormat": "Swap Used",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Disk & Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk I/O (Read/Write)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "Read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "Write {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Disk I/O Operations (IOPS)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "Reads {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_writes_completed_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "Writes {{device}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Filesystem Usage by Mountpoint",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{instance=~\"$instance\", fstype!=\"tmpfs\"} * 100) / node_filesystem_size_bytes{instance=~\"$instance\", fstype!=\"tmpfs\"})",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\", device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\", device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },

    {
      "id": 103,
      "type": "row",
      "title": "Load & Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "System Load Average (1m/5m/15m)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_load1{instance=~\"$instance\"}",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=~\"$instance\"}",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=~\"$instance\"}",
          "legendFormat": "15m",
          "refId": "C"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Network Errors & Drops",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "RX errors {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "TX errors {{device}}",
          "refId": "B"
        },
        {
          "expr": "rate(node_network_receive_drop_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "RX drops {{device}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 104,
      "type": "row",
      "title": "Connectivity, DNS & Advanced Signals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "TCP Established Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_netstat_Tcp_CurrEstab{instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Open File Descriptors",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_filefd_allocated{instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 20,
      "type": "gauge",
      "title": "Conntrack Table Usage %",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * node_nf_conntrack_entries{instance=~\"$instance\"} / node_nf_conntrack_entries_limit{instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "DNS Probe Success",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Requires a blackbox or DNS probe exporter to expose probe_success metrics.",
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_dns\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAIL", "color": "red" },
                "1": { "text": "OK", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    }
  ]
}
