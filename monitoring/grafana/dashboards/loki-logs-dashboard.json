{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.2"
    },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "title": "Loki - Logs Dashboard",
  "uid": "loki-logs-dashboard",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["loki", "logs", "promtail"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search text (regex)",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Log Lines (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Lines (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} |~ \"(?i)error|exception|fatal|panic\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Warning Lines (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} |~ \"(?i)warn\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Services",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(count by (service) (count_over_time({service=~\"$service\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" }
    },

    {
      "id": 101,
      "type": "row",
      "title": "Log Volume & Trends",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Log Volume by Service",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Error Log Rate by Service",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)error|exception|fatal\" [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "piechart",
      "title": "Log Share by Service",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"}[1h]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Log Rate by Container",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({service=~\"$service\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 102,
      "type": "row",
      "title": "Live Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 20,
      "type": "logs",
      "title": "All Logs (filtered by service + search)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{service=~\"$service\"} |~ \"(?i)$search\"", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Errors Only",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"(?i)error|exception|fatal|panic\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Service Hotspots",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Error Ratio % by Service",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "100 * (sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)error|exception|fatal|panic\" [5m])) / clamp_min(sum by (service) (count_over_time({service=~\"$service\"}[5m])), 1))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 23,
      "type": "piechart",
      "title": "Warning Share by Service",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)warn\" [1h]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 24,
      "type": "logs",
      "title": "Recent Critical Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 47 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"(?i)error|exception|fatal|panic\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ]
}
